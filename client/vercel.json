{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://tradetrack-production-f05b.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "https://tradetrack-smoky.vercel.app" }
      ]
    }
  ]
}